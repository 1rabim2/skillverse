# Copy to .env and set real values
MONGO_URI=mongodb://127.0.0.1:27017/skillverse
PORT=4000
JWT_SECRET=replace_with_a_secure_random_value

# Google Identity Services (for /api/auth/google)
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# SMTP (optional) - if absent, emails are printed to the server console
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=username
SMTP_PASS=password
SMTP_FROM=My App <no-reply@example.com>

# Optional SMTP flags
# SMTP_SECURE=true        # force secure=true (defaults to true when port=465)
# SMTP_REQUIRE_TLS=true   # force STARTTLS upgrade
# SMTP_TLS_REJECT_UNAUTHORIZED=false # allow self-signed certs (not recommended)
# SMTP_NAME=skillverse.local

# URLs used in emails / links
BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173

# Dev convenience: disable mongodb-memory-server fallback if it fails on your machine (e.g. Windows spawn EPERM)
DISABLE_EMBEDDED_MONGO=false

# Khalti (sandbox / live) - monthly subscription payments
# Sandbox keys usually start with: test_public_key_... / test_secret_key_...
# Sandbox base: https://dev.khalti.com (recommended for testing)
# Live base: set to what your Khalti live docs/account requires
KHALTI_BASE_URL=https://dev.khalti.com
KHALTI_SECRET_KEY=test_secret_key_replace_me
# Amount in paisa (NPR * 100). Example: 99900 = NPR 999.00
KHALTI_MONTHLY_AMOUNT=99900

# Subscription reminder emails (optional)
SUBSCRIPTION_REMINDERS_ENABLED=true
SUBSCRIPTION_REMINDER_DAYS=3
SUBSCRIPTION_REMINDER_INTERVAL_HOURS=12
