# Copy to .env and set real values
MONGO_URI=mongodb://127.0.0.1:27017/skillverse
PORT=4000
JWT_SECRET=replace_with_a_secure_random_value

# SMTP (optional) - if absent, emails are printed to the server console
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=username
SMTP_PASS=password
SMTP_FROM=My App <no-reply@example.com>

# URLs used in emails / links
BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173
